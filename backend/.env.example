APP_NAME="SaaS Accounting"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Central Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=saas_accounting_central
DB_USERNAME=postgres
DB_PASSWORD=

# Tenant Database Prefix
TENANT_DB_PREFIX=tenant_

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Payment Gateway (Stripe)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Tenant Backups (S3-compatible storage — separate from app uploads)
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_USE_PATH_STYLE_ENDPOINT=false

# Path to the pg_dump/pg_restore/psql binaries if not on PATH
PG_DUMP_BINARY=pg_dump
PG_RESTORE_BINARY=pg_restore
PSQL_BINARY=psql

# How long to keep backup storage (days) and the minimum number of
# most-recent backups to always retain per tenant regardless of age
BACKUP_RETENTION_DAYS=30
BACKUP_KEEP_MINIMUM=3
