APP_NAME=KimoERP
APP_ENV=production
APP_KEY=base64:GENERATE_A_NEW_KEY_USING_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_URL=https://erp.yourdomain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=erp_production
DB_USERNAME=erp_user
DB_PASSWORD=YOUR_SECURE_PASSWORD

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS="erp.yourdomain.com,localhost"
SESSION_DOMAIN=".yourdomain.com"
